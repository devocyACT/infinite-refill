# Infinite Refill 配置示例
# 复制此文件为 .env 并填入你的配置

# ============================================
# 必需配置
# ============================================

# 服务器地址
SERVER_URL=https://your-server.com

# 用户密钥（请替换为你的实际密钥）
USER_KEY=your-user-key-here

# 账号文件目录（绝对路径或相对路径）
ACCOUNTS_DIR=./accounts

# ============================================
# 池配置
# ============================================

# 目标账号池大小
TARGET_POOL_SIZE=10

# 总持有账号上限
TOTAL_HOLD_LIMIT=50

# ============================================
# 调度器配置
# ============================================

# 是否启用调度器
SCHEDULER_ENABLED=false

# 定时任务间隔（分钟）
SCHEDULER_INTERVAL_MINUTES=30

# ============================================
# 探测配置
# ============================================

# 并发探测数量
PROBE_PARALLEL=6

# 连接超时（秒）
PROBE_CONNECT_TIMEOUT=5

# 最大探测时间（秒）
PROBE_MAX_TIME=15

# Worker Pool 超时（秒）
PROBE_WAIT_TIMEOUT=600

# ============================================
# Topup 配置
# ============================================

# 连接超时（秒）
TOPUP_CONNECT_TIMEOUT=10

# 最大请求时间（秒）
TOPUP_MAX_TIME=360

# 重试次数
TOPUP_RETRY=3

# 重试延迟（秒）
TOPUP_RETRY_DELAY=3

# ============================================
# 清理配置
# ============================================

# 需要删除的状态码（逗号分隔）
CLEAN_DELETE_STATUSES=401,429

# 账号过期天数
CLEAN_EXPIRED_DAYS=30

# ============================================
# 代理配置
# ============================================

# 代理模式：auto/direct/proxy/mixed
PROXY_MODE=auto

# 代理地址（可选）
PROXY_URL=

# WHAM 探测代理模式
WHAM_PROXY_MODE=auto

# 服务器请求代理模式
SERVER_PROXY_MODE=auto

# ============================================
# 闭环配置
# ============================================

# 最大迭代次数
LOOP_MAX_ITERATIONS=6
